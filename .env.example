# Contact form — email address that receives portfolio contact submissions
CONTACT_RECEIVER_EMAIL=

# Hashnode publication host — RSS feed origin URL (e.g. jumalaw98.hashnode.dev)
HASHNODE_PUBLICATION_HOST=

# Monitor email addresses (from/to for uptime/health checks)
MONITOR_EMAIL_FROM=
MONITOR_EMAIL_TO=

# Monitor webhook URL for health-check notifications
MONITOR_WEBHOOK_URL=

# Public site URL (used for canonical links, social share URLs, RSS feed)
NEXT_PUBLIC_SITE_URL=

# Resend API key for transactional emails (contact form delivery)
RESEND_API_KEY=

# Upstash Redis REST URL and token (rate limiting, session cache)
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_URL=

# ─── Blog publishing pipeline (Phase 1-2+) ─────────────────────────────────────

# dev.to API key — used to mirror new blog posts to dev.to with a canonical link
# back to this portfolio. Get yours from https://dev.to/settings/extensions
DEVTO_API_KEY=

# Buffer API key — used in a later phase for LinkedIn/X cross-posting.
# Not yet consumed by any code in this phase; safe to leave blank for now.
BUFFER_API_KEY=

# Buffer channel IDs for LinkedIn and X — used in a later phase.
BUFFER_LINKEDIN_CHANNEL_ID=
BUFFER_X_CHANNEL_ID=

# Gemini API key (Google AI Studio) — used in a later phase for automated
# social hook generation. Not yet consumed by any code in this phase.
GEMINI_API_KEY=

# OpenRouter API key — fallback LLM provider for the same later phase.
OPENROUTER_API_KEY=
