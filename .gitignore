# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs

# ─── Package manager caches (do NOT ignore lock files) ───────────────────────
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn/releases
.pnpm-store/

# ─── Next.js build output ────────────────────────────────────────────────────
/.next/
/out/
/build/

# ─── Static export & PWA generated files ─────────────────────────────────────
/public/sw.js
/public/workbox-*.js
/public/worker-*.js
/public/fallback-*.js

# ─── Environment variables ───────────────────────────────────────────────────
# .env.local.example IS committed — it serves as the reference template.
# All actual secret-bearing env files are ignored below.
.env
.env.local
.env.*.local

# ─── TypeScript ──────────────────────────────────────────────────────────────
# next-env.d.ts is auto-generated by Next.js on every build — never commit it.
next-env.d.ts
*.tsbuildinfo

# ─── Test & coverage output ──────────────────────────────────────────────────
/coverage/
/.nyc_output/

# ─── Debug / logs ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
# Keep .vscode/extensions.json and .vscode/settings.json committed so all
# contributors share the same recommended extensions and workspace settings.
# Only ignore personal / machine-specific files:
.vscode/*.log
.vscode/launch.json
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ─── Certificates / keys ─────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Deployment ──────────────────────────────────────────────────────────────
.vercel

# ─── Agent / AI config (not for public repos) ────────────────────────────────
CLAUDE.md
AGENTS.md
.agents/
.gemini/
